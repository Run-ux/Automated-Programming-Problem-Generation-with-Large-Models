# OpenAI-compatible LLM 配置
# 将此文件复制为 .env 后，填写真实 API Key。
LLM_API_KEY=你的API_Key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.6-plus
LLM_TIMEOUT_S=360

# 题包迭代配置
PACKAGE_ITERATIONS=3
WRONG_SOLUTION_KILL_RATE=0.8

# 本地执行超时配置，单位：秒
PACKAGE_RUN_TIMEOUT_S=2.0
PACKAGE_LARGE_RUN_TIMEOUT_S=6.0
